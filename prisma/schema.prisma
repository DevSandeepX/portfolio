
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

// User



enum UserRole{
  ADMIN
  CLIENT
}

model User{
  id String @id @default(uuid())
  clerkId String @unique
  name String?
  email String @unique
  avatarUrl String?
  role UserRole @default(CLIENT)
  approvals Approval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?

  @@index([email])
  @@index([name])
}


// Project
model Project{
  id String @id @default(uuid())
  title String
  slug String @unique
  githubUrl String?
  liveUrl String?
  isPublished Boolean @default(true)
  order Int @default(0)
  projectImages ProjectImage[]
  isFeatured Boolean @default(false)

  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isFeatured])
}

// Image

model Image{
 id String @id @default(uuid())

 url String
 publicId String?
 alt String?
 width Int?
 height Int?

 projectImages ProjectImage[]

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
}


model ProjectImage{
  id String @id @default(uuid())

   
 projectId String
 project Project @relation(fields: [projectId],references: [id],onDelete: Cascade)

  
 imageId String
 image Image @relation(fields: [imageId],references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// Approvel

model Approval{
 id String @id @default(uuid())
 title String
 description String?
 
 userId String
 user User @relation(fields: [userId],references: [id],onDelete: Cascade)
 

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt

 @@index([userId])
}

// Tech

model Category {
  id String @id @default(uuid())

  title String
  slug String @unique
  description String?

  parentId String?

  parent Category? @relation( "CategoryTree", fields: [parentId],references: [id])

  children Category[] @relation("CategoryTree")

  skills Skill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Skill{
 id String @id @default(uuid())
 title String
 slug String @unique
 description String?
 
 categoryId String
 category Category @relation(fields: [categoryId],references: [id],onDelete: Cascade)
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt

 @@index([slug])
 @@index([categoryId])
 @@index([title])
}

model Setting {
  id String @id @default(uuid())

  // Site
  siteTitle       String
  siteDescription String?
  siteUrl         String?
  faviconUrl      String?

  // SEO
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?

  // Personal
  fullName        String
  designation     String

  // Contact
  email           String?
  phone           String?
  location        String?

  // Assets
  profileImage    String?
  resumeUrl       String?

  // Social
  githubUrl       String?
  linkedinUrl     String?
  twitterUrl      String?
  instagramUrl    String?
  youtubeUrl      String?
  facebookUrl     String?

  // Portfolio
  isAvailableForWork Boolean @default(true)
 experienceYears Int? @default(2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hero {
  id String @id @default(uuid())

  badge           String?
  title           String
  highlightedText String?

  subtitle        String?
  description     String?

  profileImage    String?
  bannerImage     String?

  primaryButtonText String?
  primaryButtonUrl  String?

  secondaryButtonText String?
  secondaryButtonUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}